{
  "schema_version": 1,
  "diagram_type": "workflow",
  "meta": {
    "title": "Omniskill Workflow",
    "subtitle": "install or clone a skill-tree bundle, then call the entry skill",
    "output": "assets/diagrams/omniskill-how-it-works.html"
  },
  "lanes": [
    { "id": "command", "label": "User command" },
    { "id": "installer", "label": "Omniskill install runtime" },
    { "id": "agent", "label": "Agent runtime" }
  ],
  "nodes": [
    {
      "id": "install",
      "lane": "command",
      "col": 0,
      "type": "frontend",
      "label": "Install",
      "sublabel": "or clone"
    },
    {
      "id": "source",
      "lane": "command",
      "col": 1,
      "type": "cloud",
      "label": "Source",
      "sublabel": "bundled / local / git"
    },
    {
      "id": "manifest",
      "lane": "command",
      "col": 3,
      "type": "database",
      "label": "workflow.json",
      "sublabel": "skills + steps",
      "width": 104
    },
    {
      "id": "resolve",
      "lane": "installer",
      "col": 2,
      "type": "backend",
      "label": "Resolve Skills",
      "sublabel": "entry + sub-skills",
      "width": 108
    },
    {
      "id": "targets",
      "lane": "installer",
      "col": 3,
      "type": "messagebus",
      "label": "Targets",
      "sublabel": "agent homes"
    },
    {
      "id": "record",
      "lane": "installer",
      "col": 5,
      "type": "database",
      "label": "Workflow Record",
      "sublabel": ".omniskill",
      "width": 104
    },
    {
      "id": "entry",
      "lane": "agent",
      "col": 1,
      "type": "security",
      "label": "Entry Skill",
      "sublabel": "what users call"
    },
    {
      "id": "tree",
      "lane": "agent",
      "col": 3,
      "type": "backend",
      "label": "Skill Tree",
      "sublabel": "ordered workflow"
    },
    {
      "id": "result",
      "lane": "agent",
      "col": 5,
      "type": "external",
      "label": "Workflow Result",
      "sublabel": "agent output",
      "width": 104
    }
  ],
  "edges": [
    { "from": "install", "to": "source", "variant": "emphasis" },
    { "from": "source", "to": "manifest" },
    {
      "from": "manifest",
      "to": "resolve",
      "label": "validate manifest",
      "variant": "emphasis",
      "fromSide": "bottom",
      "toSide": "top",
      "route": "drop",
      "labelSegment": 1
    },
    { "from": "resolve", "to": "targets" },
    {
      "from": "targets",
      "to": "record",
      "label": "persist install",
      "variant": "dashed",
      "labelDy": -12
    },
    {
      "from": "manifest",
      "to": "entry",
      "variant": "security",
      "fromSide": "bottom",
      "toSide": "top",
      "route": "drop"
    },
    { "from": "entry", "to": "tree", "variant": "emphasis" },
    { "from": "tree", "to": "result", "variant": "emphasis" }
  ],
  "cards": [
    {
      "dot": "cyan",
      "title": "Bundle Contract",
      "items": [
        "workflow.json names every required skill",
        "One callable entry skill can coordinate the tree",
        "install and clone share the same operation"
      ]
    },
    {
      "dot": "emerald",
      "title": "Install State",
      "items": [
        "Skills are copied to selected agent targets",
        "A normalized record is saved under .omniskill",
        "Public git sources are resolved before install"
      ]
    },
    {
      "dot": "violet",
      "title": "Runtime Model",
      "items": [
        "Users call the entry skill after restarting the agent",
        "The agent follows the ordered sub-skills",
        "Loop state is stored under the Omniskills home"
      ]
    }
  ]
}
