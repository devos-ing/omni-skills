{
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "files": {
    "includes": [
      "**",
      "!assets/diagrams",
      "!node_modules",
      "!landing/.next",
      "!bun.lock",
      "!.bun-cache",
      "!.devos",
      "!.*superpower",
      "!.omniskills",
      "!.omniskill",
      "!.ponyrace",
      "!coverage",
      "!dist",
      "!.worktrees",
      "!work",
      "!packages"
    ]
  }
}
