{
  "schemaVersion": "0.1",
  "kind": "team",
  "name": "startup-team",
  "version": "0.3.0",
  "description": "Install a startup team as one goal-oriented Omniskills bundle: a startup-goal coordinator plus CEO, CTO, product manager, web-design lead, engineering manager, founding engineer, and QA lead.",
  "coordinator": "./skills/startup-goal",
  "members": [
    "catalog:ceo",
    "catalog:cto",
    "catalog:product-manager",
    "catalog:web-design",
    "catalog:engineering-manager",
    "catalog:founding-engineer",
    "catalog:qa-lead"
  ],
  "orchestration": {
    "roles": {
      "./skills/startup-goal": {
        "tier": "deep",
        "access": "read-only",
        "consultation": "receive"
      },
      "catalog:ceo": {
        "tier": "deep",
        "access": "read-only",
        "consultation": "request"
      },
      "catalog:cto": {
        "tier": "deep",
        "access": "read-only",
        "consultation": "request"
      },
      "catalog:product-manager": {
        "tier": "deep",
        "access": "read-only",
        "consultation": "request"
      },
      "catalog:web-design": {
        "tier": "deep",
        "access": "read-only",
        "consultation": "request"
      },
      "catalog:engineering-manager": {
        "tier": "deep",
        "access": "read-only",
        "consultation": "request"
      },
      "catalog:founding-engineer": {
        "tier": "deep",
        "access": "read-only",
        "consultation": "request"
      },
      "catalog:qa-lead": {
        "tier": "deep",
        "access": "read-only",
        "consultation": "request"
      },
      "mattpocock:implement": {
        "tier": "standard",
        "access": "workspace-write",
        "consultation": "request"
      }
    },
    "support": {
      "explorer": {
        "tier": "fast",
        "access": "read-only",
        "consultation": "request"
      }
    }
  },
  "skills": [
    {
      "source": "./skills/startup-goal",
      "entry": true
    },
    {
      "source": "catalog:ceo"
    },
    {
      "source": "catalog:cto"
    },
    {
      "source": "catalog:product-manager"
    },
    {
      "source": "catalog:web-design"
    },
    {
      "source": "catalog:engineering-manager"
    },
    {
      "source": "catalog:founding-engineer"
    },
    {
      "source": "catalog:qa-lead"
    },
    {
      "source": "superpowers:brainstorming",
      "repo": "obra/superpowers"
    },
    {
      "source": "mattpocock:implement",
      "repo": "https://github.com/mattpocock/skills/tree/v1.1.0"
    }
  ],
  "steps": [
    {
      "id": "requirements",
      "title": "Interview and approve startup requirements",
      "skill": "superpowers:brainstorming",
      "gate": "human_approval",
      "instruction": "Interview the user one question at a time until the startup goal, constraints, success criteria, and required roles are clear. Present the requirement brief and wait for explicit human approval before routing the startup flow."
    },
    {
      "id": "route",
      "title": "Route the approved startup goal",
      "skill": "./skills/startup-goal",
      "gate": "human_approval",
      "instruction": "Use the approved requirement brief to choose the needed startup roles, prepare role briefs, and wait for explicit human approval before role execution."
    },
    {
      "id": "strategy",
      "title": "Clarify company direction",
      "skill": "catalog:ceo",
      "gate": "human_approval"
    },
    {
      "id": "product",
      "title": "Shape product scope",
      "skill": "catalog:product-manager"
    },
    {
      "id": "design",
      "title": "Set web interface direction and motion quality",
      "skill": "catalog:web-design"
    },
    {
      "id": "technology",
      "title": "Set technical direction",
      "skill": "catalog:cto"
    },
    {
      "id": "delivery",
      "title": "Plan engineering execution",
      "skill": "catalog:engineering-manager"
    },
    {
      "id": "implementation",
      "title": "Frame the implementation slice",
      "skill": "catalog:founding-engineer"
    },
    {
      "id": "implement",
      "title": "Implement the planned change",
      "skill": "mattpocock:implement"
    },
    {
      "id": "qa",
      "title": "Verify release readiness",
      "skill": "catalog:qa-lead"
    }
  ]
}
