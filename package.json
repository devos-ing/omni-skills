{
	"name": "adhd.ai",
	"version": "0.1.0",
	"license": "MIT",
	"private": true,
	"type": "module",
	"bin": {
		"adhd-ai": "./src/index.ts"
	},
	"scripts": {
		"build": "bun build ./src/index.ts --target bun --outdir dist",
		"start": "bun run ./src/index.ts",
		"test": "bun test",
		"typecheck": "bunx tsc --noEmit",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"check": "biome check .",
		"check:write": "biome check --write .",
		"prepare": "husky"
	},
	"devDependencies": {
		"@types/bun": "^1.3.2",
		"@biomejs/biome": "1.9.4",
		"husky": "^9.1.7",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@linear/sdk": "^83.0.0",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3"
	}
}
