{
  "name": "goal-court",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "goal-court": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "bundled-skills"
  ],
  "scripts": {
    "dev": "bun src/cli.ts",
    "build": "bun build --target=bun --outfile=dist/cli.js src/cli.ts",
    "test": "bun test",
    "coverage": "bun test --coverage --coverage-reporter=lcov --coverage-dir=coverage && bun scripts/check-coverage.ts 90 coverage/lcov.info",
    "coverage:check": "bun scripts/check-coverage.ts 90 coverage/lcov.info",
    "deps:check-recency": "bun scripts/check-package-recency.ts",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check . && bun run typecheck && bun run coverage",
    "prepack": "bun run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "commander": "^14.0.2",
    "picocolors": "^1.1.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@types/bun": "^1.3.2",
    "husky": "^9.1.7",
    "typescript": "^5.9.3"
  }
}
