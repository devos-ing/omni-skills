{
	"name": "adhdai",
	"version": "0.0.1",
	"license": "MIT",
	"private": false,
	"type": "module",
	"files": ["dist", "README.md", "LICENSE"],
	"bin": {
		"adhd-ai": "./dist/index.js"
	},
	"scripts": {
		"build": "bun build ./src/index.ts --target bun --outdir dist",
		"start": "bun run ./src/index.ts",
		"publish:version": "bun run ./scripts/publish-version.ts",
		"review:hourly": "bun run ./src/index.ts cron --job hourly-pr-review",
		"test": "bun test",
		"typecheck": "bunx tsc --noEmit",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"check": "biome check .",
		"check:write": "biome check --write .",
		"prepare:publish": "bun run check && bun run typecheck && bun test && bun run build && npm pack --dry-run --ignore-scripts",
		"prepare": "husky"
	},
	"devDependencies": {
		"@types/bun": "^1.3.2",
		"@biomejs/biome": "1.9.4",
		"husky": "^9.1.7",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@linear/sdk": "^83.0.0",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3"
	}
}
