{
	"name": "show-me-ur-agents",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.8",
	"engines": {
		"bun": ">=1.3.0"
	},
	"trustedDependencies": [
		"@embedded-postgres/darwin-arm64",
		"@embedded-postgres/darwin-x64",
		"@embedded-postgres/linux-arm",
		"@embedded-postgres/linux-arm64",
		"@embedded-postgres/linux-ia32",
		"@embedded-postgres/linux-ppc64",
		"@embedded-postgres/linux-x64",
		"@embedded-postgres/windows-x64"
	],
	"workspaces": ["packages/*"],
	"scripts": {
		"preinstall": "bun run ./scripts/enforce-bun.ts",
		"build": "bun run --filter devos-agents build && bun run --filter create-devos-plugin build && bun run --filter create-devos-workflow build && bun run --filter devos build",
		"build:landing": "bun run --filter landing build",
		"build:server": "bun -e \"console.log('No server workspace package is present yet. Add the ROY-120 server package, then wire this script to its build command.')\"",
		"build:web": "bun run --filter web build",
		"dev": "bun run ./scripts/dev.ts",
		"dev:landing": "bun run --filter landing dev",
		"dev:daemon": "bun run ./packages/cli/src/index.ts daemon",
		"dev:server": "bun run --filter devos-server start",
		"dev:worker": "bun run ./scripts/dev-worker.ts",
		"dev:web": "bun run --filter web dev:turbopack",
		"db:migrate": "bun run --filter devos-db migrate",
		"db:seed": "bun run --filter devos-db seed",
		"db:backup": "bun run --filter devos-db backup",
		"db:view": "bun run ./scripts/view-server-db.ts",
		"db:recover": "bun run ./scripts/recover-server-db.ts",
		"smoke": "bun test packages/cli/tests/smoke-flow.test.ts",
		"publish:version": "bun run --filter devos publish:version",
		"test": "bun run ./scripts/test-lane.ts default",
		"test:fast": "bun run ./scripts/test-lane.ts fast",
		"test:db": "bun run ./scripts/test-lane.ts db",
		"test:e2e": "bun run ./scripts/test-lane.ts e2e",
		"test:coverage": "bun run ./scripts/test-lane.ts coverage",
		"typecheck": "bun run --filter devos-agents typecheck && bun run --filter adapters typecheck && bun run --filter create-devos-plugin typecheck && bun run --filter create-devos-workflow typecheck && bun run --filter devos-db typecheck && bun run --filter devos typecheck && bun run --filter web typecheck && bun run --filter landing typecheck",
		"format": "bun run biome format --write .",
		"lint": "bun run biome lint .",
		"check": "bun run biome check .",
		"check:write": "bun run biome check --write .",
		"cron:once": "bun run ./packages/server/src/cron/run-cron.ts --once",
		"prepare:publish": "bun run --filter devos prepare:publish",
		"changeset": "changeset",
		"prepare": "bun run ./scripts/prepare.ts"
	},
	"devDependencies": {
		"@devos/tsconfig": "workspace:*",
		"@biomejs/biome": "1.9.4",
		"@changesets/cli": "^2.31.0",
		"adapters": "workspace:*",
		"create-devos-plugin": "workspace:*",
		"create-devos-workflow": "workspace:*",
		"devos-agents": "workspace:*",
		"devos": "workspace:*",
		"devos-db": "workspace:*",
		"husky": "^9.1.7"
	}
}
