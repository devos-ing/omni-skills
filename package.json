{
	"name": "show-me-ur-agents",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.8",
	"engines": {
		"bun": ">=1.3.0"
	},
	"workspaces": ["packages/*"],
	"scripts": {
		"preinstall": "bun run ./scripts/enforce-bun.ts",
		"build": "bun run --filter devos build",
		"build:landing": "bun run --filter landing build",
		"build:server": "bun -e \"console.log('No server workspace package is present yet. Add the ROY-120 server package, then wire this script to its build command.')\"",
		"build:web": "bun run --filter web build",
		"dev:landing": "bun run --filter landing dev",
		"dev:daemon": "bun run ./packages/cli/src/index.ts daemon --cli-only",
		"dev:server": "bun run --filter devos-server start",
		"dev:web": "bun run --filter web dev",
		"dev": "bun run ./scripts/dev.ts",
		"db:view": "bun run ./scripts/view-server-db.ts",
		"db:recover": "bun run ./scripts/recover-server-db.ts",
		"start": "bun run ./packages/cli/src/index.ts",
		"smoke": "bun test packages/cli/tests/smoke-flow.test.ts",
		"publish:version": "bun run --filter devos publish:version",
		"review:hourly": "bun run --filter devos-server review:hourly",
		"test": "bun test packages/cli/tests",
		"typecheck": "bun run --filter devos typecheck && bun run --filter web typecheck && bun run --filter landing typecheck",
		"format": "bun run biome format --write .",
		"lint": "bun run biome lint .",
		"check": "bun run biome check .",
		"check:write": "bun run biome check --write .",
		"cron:once": "bun run --filter devos-server cron:once",
		"review:hourly:once": "bun run --filter devos-server review:hourly:once",
		"prepare:publish": "bun run --filter devos prepare:publish",
		"changeset": "changeset",
		"prepare": "bun run ./scripts/prepare.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@changesets/cli": "^2.31.0",
		"devos": "workspace:*",
		"husky": "^9.1.7"
	}
}
