{
	"name": "adhdai",
	"version": "0.0.1",
	"license": "MIT",
	"private": false,
	"type": "module",
	"files": ["dist", "README.md", "LICENSE"],
	"bin": {
		"adhd": "dist/index.js"
	},
	"exports": {
		"./features/config": "./src/features/config/index.ts",
		"./features/server/cli-command-executor": "./src/features/server/cli-command-executor.ts",
		"./features/types": "./src/features/types.ts",
		"./features/workflow/workflow": "./src/features/workflow/workflow.ts",
		"./utils/logger": "./src/utils/logger.ts"
	},
	"scripts": {
		"build": "bun build ./src/index.ts --target bun --outdir dist",
		"start": "bun run ./src/index.ts",
		"smoke": "bun test tests/smoke-flow.test.ts",
		"publish:version": "bun run ./scripts/publish-version.ts",
		"test": "cd ../.. && bun test packages/cli/tests",
		"typecheck": "bunx tsc --noEmit",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"check": "biome check .",
		"check:write": "biome check --write .",
		"prepare:publish": "bun run check && bun run typecheck && bun run test && bun run build && npm --cache ./.npm-cache pack --dry-run --ignore-scripts"
	},
	"devDependencies": {
		"@types/bun": "^1.3.2",
		"@types/node": "^24.10.0",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@linear/sdk": "^83.0.0",
		"adhdai-server": "workspace:*",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3"
	}
}
