		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@electric-sql/pglite": "^0.3.14",
		"devos": "workspace:*",
		"drizzle-orm": "^0.44.7",
		"express": "^5.2.1",
		"express-openapi-validator": "^5.6.0",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"resend": "^6.2.0",
		"swagger-ui-express": "^5.0.1",
