	"private": true,
	"type": "module",
	"exports": {
		"./cron": "./src/cron/index.ts",
		"./db": "./src/db/index.ts"
	},
	"scripts": {
		"build": "vite build",
		"start": "bun run ./src/index.ts",
		"cron": "bun run ./src/cron/run-cron.ts",
		"cron:once": "bun run ./src/cron/run-cron.ts --once",
		"review:hourly": "bun run ./src/cron/run-cron.ts --job hourly-pr-review",
		"review:hourly:once": "bun run ./src/cron/run-cron.ts --once --job hourly-pr-review",
		"test": "bun test tests",
		"typecheck": "bunx tsc --noEmit",
		"check": "biome check ."
	},
	"devDependencies": {
		"@types/bun": "^1.3.2",
